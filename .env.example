# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bolao:secret@localhost:5432/bolao_trovao

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# OAuth Google — deixe em branco para desabilitar o login social.
# Produção: use um OAuth client dedicado e publique a consent screen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Deve ser idêntico à redirect URI registrada no Google Cloud Console.
# Produção: https://seudominio.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── SMTP (email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Bolão Trovão <noreply@bolao.local>

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@bolao.local

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública do frontend (redirect pós-login Google + e-mails).
# Produção: https://seudominio.com
APP_URL=http://localhost:3000
PORT=3001
# Em production o cookie de refresh token vira `secure` (exige HTTPS).
NODE_ENV=development

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
